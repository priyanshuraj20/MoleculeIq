# Environment Configuration Template for MoleculeIQ Backend
# Copy this file to .env and fill in your own values. Never commit .env to Git.

# Application Settings
APP_NAME=MoleculeIQ API
APP_ENV=development
DEBUG=True
PORT=8000
HOST=0.0.0.0

# CORS Allowed Origins (Comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Supabase — get these from your project dashboard at supabase.com
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_KEY=your_supabase_anon_or_publishable_key_here
